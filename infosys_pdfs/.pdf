<script>
    (function(){
        var hashId = window.location.hash;
        if (hashId && hashId.startsWith('#theme-')) {
            var theme = hashId.split('-')[1]; if (theme) document.body.classList.add("theme-mode", theme);
        }
    })()
</script>


