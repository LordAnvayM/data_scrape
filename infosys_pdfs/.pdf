<script type="text/javascript">

  // Show the signup tab active when redirect to signup page
  const url = window.location.href.split("next=");
  const signupUrl = document.querySelector("#signup").dataset.signup; 
  if(signupUrl && url[1]=== signupUrl){
    const signupToggle = document.querySelector("#signup-toggle");
    const loginToggle = document.querySelector("#login-toggle");
    const loginTab = document.querySelector("#login");
    const signuptab = document.querySelector("#signup");

    // handling the classes while switching the tabs
    loginTab.classList.remove("active"); 
    loginToggle.classList.remove("active");
    signupToggle.classList.add("active");
    signuptab.classList.add("active","in");

  }
   

  // Go to sign tab while clicking the signup button
  function handleClass(event) {
    let currElem = event.target;
    let parentElem = currElem.closest(".tab-content");
    let navTabsElem = parentElem.previousElementSibling;
    let signUpNavTabElem = navTabsElem.querySelectorAll('[data-signupnavtab]');
    signUpNavTabElem[0].click()
  }
</script>
