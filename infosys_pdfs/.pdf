<script>
    document.getElementById('_login_form').addEventListener('submit', async function(e) {
        e.preventDefault();
        try {
            if (window.TrendlyneApp && "verify_captcha" in TrendlyneApp) {
                const token = await TrendlyneApp.verify_captcha(TrendlyneApp.captcha_actions.login);
                const tokenInput = document.getElementById('-g-recaptcha-token-login');
                tokenInput.value = token;
                this.submit();
            }
        } catch (error) {
            console.error('reCAPTCHA verification failed:', error);
        }
    });
</script>
<script type="text/javascript">
    // adding the email in the login with OTP url and redirecting to login page.
    function redirectToLoginWithOtp(event) {

        const loginWithOtpButtonElement = document.getElementById("login-with-otp-form");

        if (loginWithOtpButtonElement === undefined || loginWithOtpButtonElement === null) return;

        const currLoginWithOtpUrl = loginWithOtpButtonElement.href;

        if (currLoginWithOtpUrl === null) return;

        const email = document.getElementById("id_login").value;

        const EMAIL_REGEX = new RegExp(
            /^(([^<>()[\]\\.,;:\s@"]+(\.[^<>()[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/
        );

        if (!email || email === "" || !EMAIL_REGEX.test(email)) return;

        event.preventDefault();

        const url = new URL(currLoginWithOtpUrl);

        url.searchParams.set('email', email);

        window.location.href = url;
    }
</script>

<script type="text/javascript">
    // Function for show/hide password and toggle eye icon for both password & confirm password
    function showPassword(event){
        const currentEyeElem = event.target;
        const isCheckClass = currentEyeElem.classList.contains('fa-eye');
        const inputElement = currentEyeElem.parentElement.querySelector('.form-control') || null;
        if(isCheckClass) {
            // eye
            if(inputElement) inputElement.setAttribute('type','password');
            currentEyeElem.previousElementSibling.classList.remove('hidden');
            currentEyeElem.classList.add('hidden');
        }else {
            // eye-slash
            if(inputElement) inputElement.setAttribute('type','text');
            currentEyeElem.classList.add('hidden');
            currentEyeElem.nextElementSibling.classList.remove('hidden');
        }
    }
</script>



