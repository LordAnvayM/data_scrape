			{ "@type": "BlogPosting", "headline": "CUET UG Result 2025 Live: One candidate scores 100 percentile in four subjects, 17 bag top score in three subj", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122250821", "datePublished": "2025-07-04T17:52:18+05:30", "articleBody": "CUET UG Result 2025 Live: One candidate scores 100 percentile in four subjects, 17 bag top score in three subjectsCUET UG Result 2025 Live: One candidate has scored 100 percentile in four subjects in the Common Entrance University Test-Under Graduate (CUET-UG), while 17 candidates from across the country have bagged the top score in three subjects, the National Testing Agency (NTA) on Friday announced. The NTA conducted CUET-UG in computer-based test (CBT) mode for 13,54,699 candidates. These candidates applied for various combinations of subjects for the academic session 2025-2026." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T17:52:18+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Website down ", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122246347", "datePublished": "2025-07-04T14:32:07+05:30", "articleBody": "CUET Result 2025 Live Updates: Website down " , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T14:32:07+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Steps to check", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122245859", "datePublished": "2025-07-04T14:08:51+05:30", "articleBody": "CUET Result 2025 Live Updates: Steps to checkVisit the official website: cuet.nta.nic.in or nta.ac.in Click on the link that says “CUET UG 2025 Result” or “Download Scorecard” Enter your credentials – Application Number, Roll Number, and Date of Birth Submit the details to view your result Download and print your scorecard for future admission processes Ask ChatGPT" , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T14:08:51+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: CUET UG 2025 results declared, direct link activated", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122245663", "datePublished": "2025-07-04T13:59:41+05:30", "articleBody": "CUET Result 2025 Live Updates: CUET UG 2025 results declared, direct link activatedThe CUET UG 2025 results have been officially announced by the National Testing Agency (NTA). Candidates can now access their scorecards via the active direct link at examinationservices.nic.in. Over 13 lakh students can log in using their application number and date of birth to view their results." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T13:59:41+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Merit list and counselling", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122245268", "datePublished": "2025-07-04T13:40:52+05:30", "articleBody": "CUET Result 2025 Live Updates: Merit list and counsellingCUET Result 2025 Live Updates: Participating universities, institutes, or organizations will prepare a merit list. Based on the CUET (UG) 2025 scorecard issued by the NTA, universities may conduct their own counselling processes." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T13:40:52+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Highest and lowest state applicants", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122243387", "datePublished": "2025-07-04T12:18:43+05:30", "articleBody": "CUET Result 2025 Live Updates: Highest and lowest state applicantsAccording to the analytics released by the NTA for the CUET UG 2024 results announced on July 28, Uttar Pradesh recorded the highest number of applicants. In total, 3,47,736 students registered, and 2,96,858 appeared for the exam. Delhi followed as the second-highest, with 1,56,412 registrations and 1,37,145 students appearing for CUET UG admissions." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T12:18:43+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Scheme", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122242706", "datePublished": "2025-07-04T11:46:23+05:30", "articleBody": "CUET Result 2025 Live Updates: SchemeCUET Result 2025 Live Updates: The CUET UG 2025 exam covered a total of 37 subjects, comprising 13 Indian languages, 23 domain-specific subjects, and one General Aptitude Test. Candidates could select up to five test papers, regardless of their Class 12 subject combinations." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T11:46:23+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: What was the duration of the test?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122242464", "datePublished": "2025-07-04T11:34:51+05:30", "articleBody": "CUET Result 2025 Live Updates: What was the duration of the test?CUET Result 2025 Live Updates: Each CUET UG 2025 test paper was held for a duration of 60 minutes and conducted across multiple shifts. PwBD candidates were provided with an additional 20 minutes of compensatory time for every hour of the exam." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T11:34:51+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Eligibility criteria to appear for the exam", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122242071", "datePublished": "2025-07-04T11:14:23+05:30", "articleBody": "CUET Result 2025 Live Updates: Eligibility criteria to appear for the examCUET Result 2025 Live Updates: Candidates who have either passed their Class 12 or equivalent examination or are appearing in 2025 are eligible to apply for CUET (UG). However, they must also meet the age requirements (if any) set by the specific university, institution, or organization where they wish to seek admission. Ask ChatGPT" , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T11:14:23+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: How to check scores once declared?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122241861", "datePublished": "2025-07-04T11:02:07+05:30", "articleBody": "CUET Result 2025 Live Updates: How to check scores once declared?CUET Result 2025 Live Updates: Once declared, the CUET result can be accessed from the official websites — nta.ac.in and cuet.nta.nic.in. To view their results, candidates need to log in using their application number and date of birth on the mentioned portals." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T11:02:07+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: When and where to check CUET UG 2025 result?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122241431", "datePublished": "2025-07-04T10:41:35+05:30", "articleBody": "CUET Result 2025 Live Updates: When and where to check CUET UG 2025 result?CUET Result 2025 Live Updates: As per the official update from the NTA, the CUET UG 2025 result will be released on July 4, though the exact time of release is yet to be confirmed. Once announced, the result will be available on the official websites. Along with the scorecards, the NTA will also publish subject-wise statistics and the total number of candidates who appeared and qualified." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T10:41:35+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Who will prepare the merit list?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122241296", "datePublished": "2025-07-04T10:34:02+05:30", "articleBody": "CUET Result 2025 Live Updates: Who will prepare the merit list?CUET Result 2025 Live Updates: The merit list will be created by the participating universities, institutes, or organisations using the CUET UG 2025 scores. Based on these scores, each university may also hold its own counselling process for admission to undergraduate programmes." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T10:34:02+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Steps to check the results", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122241100", "datePublished": "2025-07-04T10:24:03+05:30", "articleBody": "CUET Result 2025 Live Updates: Steps to check the resultsStep 1: Go to cuet.nta.nic.in Step 2: Click on the CUET UG 2025 result download link Step 3: On the next window, insert the roll number and registration number Step 4: Submit and download the CUET UG result 2025" , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T10:24:03+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: When were the results announced in past?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122241037", "datePublished": "2025-07-04T10:20:39+05:30", "articleBody": "CUET Result 2025 Live Updates: When were the results announced in past?CUET UG Result Date 2025: July 4 CUET UG Result Date 2024: July 28 CUET UG Result Date 2023: July 15 CUET UG Result Date 2022: September 15" , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T10:20:39+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Official websites to check", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122240816", "datePublished": "2025-07-04T10:07:45+05:30", "articleBody": "CUET Result 2025 Live Updates: Official websites to checkCUET Result 2025 Live Updates: The official websites to check and download the CUET UG 2025 scorecard are nta.ac.in and cuet.nta.nic.in." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T10:07:45+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Marking scheme", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122240754", "datePublished": "2025-07-04T10:04:20+05:30", "articleBody": "CUET Result 2025 Live Updates: Marking schemeCUET Result 2025 Live Updates: Correct answer: +5 – Incorrect answer: – 1 – Unanswered/ un-attempted: 0" , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T10:04:20+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: When and where to download CUET UG 2025 result", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122240710", "datePublished": "2025-07-04T10:01:26+05:30", "articleBody": "CUET Result 2025 Live Updates: When and where to download CUET UG 2025 resultCUET Result 2025 Live Updates: Once declared, the CUET UG 2025 result will be accessible on the official websites — cuet.nta.nic.in and nta.ac.in. To view their results, candidates need to visit either site and log in using their application number and date of birth." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T10:01:26+05:30" },{ "@type": "BlogPosting", "headline": "CUET Result 2025 Live Updates: Will there re-evaluation of announced results?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122240098", "datePublished": "2025-07-04T09:16:13+05:30", "articleBody": "CUET Result 2025 Live Updates: Will there re-evaluation of announced results?The NTA has clarified that the result will not be re-evaluated/re-checked, and no correspondence in this regard will be entertained." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T09:16:13+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: What login credentials will I need?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122239848", "datePublished": "2025-07-04T09:00:10+05:30", "articleBody": "CUET 2025 Results Scorecard Live: What login credentials will I need?To log in, students will need: CUET UG application number Date of birth" , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T09:00:10+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: How many students appeared last year?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122239604", "datePublished": "2025-07-04T08:42:06+05:30", "articleBody": "CUET 2025 Results Scorecard Live: How many students appeared last year?A total of 13,47,618 students registered for CUET UG last year. Of them, as many as 7.17 lakh were male candidates, 6.30 lakh were female candidates and seven were transgender students." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T08:42:06+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: Is there any negative marking?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122239447", "datePublished": "2025-07-04T08:29:26+05:30", "articleBody": "CUET 2025 Results Scorecard Live: Is there any negative marking?Yes, there is negative marking in CUET evaluation. A mark will be deducted for each incorrect response." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T08:29:26+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: List of Deemed Universities using CUET scores", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122239204", "datePublished": "2025-07-04T08:10:41+05:30", "articleBody": "CUET 2025 Results Scorecard Live: List of Deemed Universities using CUET scoresAurora Higher Education and Research Academy Avinashilingam Institute for Home Science and Higher Education for Women Dayalbagh Educational Institute GITAM (Visakhapatnam) GITAM (Bengaluru) GITAM (Hyderabad) Gokhale Institute of Politics and Economics Graphic Era (Deemed to be University) Gujarat Vidyapith Gurukula Kangri ICFAI (Hyderabad) IIS (Deemed to be University), Jaipur Jamia Hamdard Jaypee Institute of Information Technology Lakshmibai National Institute of Physical Education Lingaya's Vidyapeeth Maharishi Markandeshwar (Deemed to be University), Mullana - Ambala Manav Rachna International Institute of Research and Studies Nehru Gram Bharati (Deemed to be University) Shobhit Institute of Engineering and Technology SRM Institute of Science and Technology (Deemed University), NCR Campus Tata Institute of Social Sciences (TISS) TERI School of Advanced Studies The Gandhigram Rural Institute (Deemed to be University) Vinayaka Mission's Research Foundation" , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T08:10:41+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: How to download CUET-UG scorecard", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122238902", "datePublished": "2025-07-04T07:52:53+05:30", "articleBody": "CUET 2025 Results Scorecard Live: How to download CUET-UG scorecardVisit the official NTA CUET website Click on the link for CUET UG 2025 result Enter your application number and date of birth Submit the login details The scorecard will appear on the screen Verify all details and download the PDF for future use" , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T07:52:53+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: Provisional and Final answer keys", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122238895", "datePublished": "2025-07-04T07:52:11+05:30", "articleBody": "CUET 2025 Results Scorecard Live: Provisional and Final answer keysThe provisional answer key for CUET-UG 2025 was released by the National Testing Agency (NTA) June 15. Candidates were given a limited window till June 20 to raise objections and submit supporting documents for any disputed answers. Following the review of all challenges, the final answer key was published on July 1, 2025. This final version is used for calculating results and cannot be challenged further." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T07:52:11+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: Minimum marks required to qualify in CUET-UG 2025", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122238877", "datePublished": "2025-07-04T07:49:37+05:30", "articleBody": "CUET 2025 Results Scorecard Live: Minimum marks required to qualify in CUET-UG 2025Candidates who score between 350 and 400 marks out of a total of 800 are generally considered as having qualified in the CUET-UG exam. However, qualifying does not guarantee admission, as each participating university sets its own cut-offs and eligibility criteria for various courses." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T07:49:37+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: Where to check CUET UG scores?", "url": "https://economictimes.indiatimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms#lbn122238866", "datePublished": "2025-07-04T07:48:37+05:30", "articleBody": "CUET 2025 Results Scorecard Live: Where to check CUET UG scores?Students can check their CUET UG results on its official website cuet.nta.nic.in." , "image":{ "@type":"ImageObject", "contentUrl":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg", "width":"1200", "height":"900", "url":"https://img.etimg.com/thumb/msid-68919906,width-1200,height-900,resizemode-4/.jpg" }, "publisher":{ "@type":"NewsMediaOrganization", "name":"Economic Times", "logo": { "@type": "ImageObject", "url": "https://img.etimg.com/thumb/msid-76939477,width-600,height-60,quality-100/economictimes.jpg", "width": "600", "height": "60" } }, "author":"Economic Times", "mainEntityOfPage":"https://m.economictimes.com/news/newsblogs/cuet-ug-results-2025-live-updates-nta-cuet-ug-result-scorecard-download-direct-link-cuet-nta-nic-in-merit-list-pdf-download-toppers-list/liveblog/122238810.cms", "dateModified":"2025-07-04T07:48:37+05:30" },{ "@type": "BlogPosting", "headline": "CUET 2025 Results Scorecard Live: Result date is 